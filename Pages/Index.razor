@page "/"
@layout MainLayout
@inject AppStateService State
@implements IDisposable

<div class="topbar">
    <div>
        <div class="topbar-title">Dashboard</div>
        <div class="topbar-sub">
            @DateTime.Now.ToString("dddd, MMMM d, yyyy") — Welcome@(State.IsLoggedIn ? $", {State.CurrentUser!.Name}" : " to CampusConnect")
        </div>
    </div>
    <div class="topbar-actions">
        @if (!State.IsLoggedIn)
        {
            <span style="color:rgba(255,255,255,0.7);font-size:13px">
                Sign in for full access
            </span>
        }
        else
        {
            <span class="badge" style="background:rgba(255,255,255,0.15);color:#fff;padding:6px 14px">
                @(State.IsAdmin ? "Admin Mode" : "Student Mode")
            </span>
        }
    </div>
</div>

<div class="page-body">

    <div class="stats-grid">
        <div class="stat-card">
            <div>
                <div class="stat-val">@State.TotalStudents</div>
                <div class="stat-lbl">Registered Students</div>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <div class="stat-val">@State.TotalBookings</div>
                <div class="stat-lbl">Active Bookings</div>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <div class="stat-val">@State.TotalEvents</div>
                <div class="stat-lbl">Upcoming Events</div>
            </div>
        </div>
        <div class="stat-card">
            <div>
                <div class="stat-val">@State.TotalLocations</div>
                <div class="stat-lbl">Campus Locations</div>
            </div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-bottom:22px">

        <div class="card">
            <div class="card-header">
                <div class="card-title">Upcoming Events</div>
                <a href="/events" class="btn btn-secondary btn-sm">View All</a>
            </div>
            <div class="card-body" style="padding-top:14px">
                @if (State.Events.Any())
                {
                    @foreach (var ev in State.Events.Take(3))
                    {
                        var d = DateTime.TryParse(ev.Date, out var dt) ? dt : DateTime.Today;
                        <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:14px">
                            <div class="event-date-box" style="width:44px;padding:6px 4px">
                                <div class="event-month">@d.ToString("MMM")</div>
                                <div class="event-day" style="font-size:18px">@d.Day</div>
                            </div>
                            <div>
                                <div style="font-weight:600;font-size:14px;color:var(--text-dark)">@ev.Title</div>
                                <div style="font-size:12px;color:var(--text-soft)">
                                     @ev.Time &nbsp;·&nbsp; @ev.LocationName
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:24px">
                        <div class="empty-text">No events yet</div>
                    </div>
                }
            </div>
        </div>
       
        <div class="card">
            <div class="card-header">
                <div class="card-title">Recent Bookings</div>
                <a href="/bookings" class="btn btn-secondary btn-sm">View All</a>
            </div>
            <div class="card-body" style="padding-top:14px">
                @if (State.Bookings.Any())
                {
                    @foreach (var b in State.Bookings.Take(4))
                    {
                        var loc = State.GetLocation(b.LocationId);
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)">
                            <div>
                                <div style="font-size:13px;font-weight:600">@b.BookingId</div>
                                <div style="font-size:12px;color:var(--text-soft)">
                                    @b.StudentName · @(loc?.Name ?? "Unknown")
                                </div>
                            </div>
                            <span class="badge @GetPriorityBadge(b.Priority)">P@b.Priority</span>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:24px">
                        <div class="empty-text">No bookings yet</div>
                    </div>
                }
            </div>
        </div>

    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">Campus Locations</div>
        </div>
        <div class="card-body">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px">
                @foreach (var loc in State.Locations)
                {
                    <div style="padding:16px;border:1.5px solid var(--border);border-radius:12px;text-align:center;background:var(--blue-ghost)">
                        <div style="font-weight:600;font-size:13px;color:var(--blue-deep)">@loc.Name</div>
                        <div style="font-size:11px;color:var(--text-soft);margin-top:3px">
                            @(loc.Capacity > 0 ? $"Cap. {loc.Capacity}" : "Entry")
                        </div>
                        <span class="badge badge-blue" style="margin-top:8px;font-size:10px">@loc.Type</span>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }

    string GetPriorityBadge(int prio) => prio >= 5 ? "badge-red" : prio == 4 ? "badge-amber" : prio == 3 ? "badge-blue" : "badge-green";
}
